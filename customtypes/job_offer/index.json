{
  "format": "custom",
  "id": "job_offer",
  "label": "Job Offer",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Titre de l'offre"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Date",
          "placeholder": "Date de publication"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Description du poste",
          "allowTargetBlank": true,
          "multi": "paragraph,preformatted,heading1,heading2,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item,rtl"
        }
      },
      "technologies": {
        "type": "Group",
        "config": {
          "label": "Technologies",
          "repeat": true,
          "fields": {
            "technology": {
              "type": "Text",
              "config": {
                "label": "Technology",
                "placeholder": ""
              }
            }
          }
        }
      },
      "recipients": {
        "type": "Group",
        "config": {
          "label": "Recipients",
          "repeat": true,
          "fields": {
            "email": {
              "type": "Text",
              "config": {
                "label": "email",
                "placeholder": "Email des destinataires"
              }
            }
          }
        }
      }
    }
  }
}
